# JWT Secret for token generation (use a strong, random string in production)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Monthly access code (shared with users)
MONTHLY_CODE=123456

# Comma-separated list of allowed email addresses
ALLOWED_EMAILS=user1@example.com,user2@example.com,user3@example.com

# Environment (development, production)
NODE_ENV=development
